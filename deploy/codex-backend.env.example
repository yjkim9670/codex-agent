# Copy this file to deploy/codex-backend.env and adjust values.
# This env file is loaded by deploy/scripts/run_codex_backend.sh and systemd user service.

# Backend bind config (local-only bind is recommended when using tailscale serve)
CODEX_BACKEND_HOST=127.0.0.1
# Keep 8080 reserved for code-server; use a dedicated backend port for Vercel/API traffic.
CODEX_BACKEND_PORT=6000
# Optional extra reservation list for run_codex_chat_server.sh auto-port selection.
# CODEX_RESERVED_PORTS=8080

# Codex backend runtime configuration
CODEX_WORKSPACE_DIR=/home/dinya
CODEX_STORAGE_SUBDIR=codex_agent/workspace/.agent_state
CODEX_CHAT_SECRET_KEY=replace-this-secret-key
CODEX_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-vercel-preview-*.vercel.app
CODEX_API_ONLY_MODE=1
CODEX_ENABLE_FILES_API=1
CODEX_ENABLE_GIT_API=1
CODEX_SKIP_GIT_REPO_CHECK=0

# Optional model/reasoning overrides
# CODEX_MODEL_OPTIONS=gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-mini
# CODEX_REASONING_OPTIONS=low,medium,high,xhigh
