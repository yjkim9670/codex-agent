# Copy this file to deploy/vercel/codex-agent-web.vercel.env and set real values.
# Example:
# cp deploy/vercel/codex-agent-web.vercel.env.example deploy/vercel/codex-agent-web.vercel.env

# Existing or new Vercel project name for apps/codex-agent-web
VERCEL_PROJECT_NAME=codex-agent-web

# Optional Vercel team scope (team slug or team ID). Leave empty for personal account.
VERCEL_SCOPE=

# Tailnet HTTPS URL for Codex backend. This must be reachable from the user's browser.
# Example: https://your-machine.your-tailnet.ts.net
# If local backend runs on 6000 via `tailscale serve`, keep this URL without `:6000`.
VITE_CODEX_API_BASE_URL=https://your-machine.your-tailnet.ts.net

# Optional label shown in the frontend UI title/header.
VITE_APP_ENV_NAME=private-tailnet
