{
  "server": {
    "host": "0.0.0.0",
    "port": 3100,
    "debug": true,
    "use_reloader": true,
    "threaded": true
  },
  "agent": {
    "workspace_dir": "./workspace",
    "storage_subdir": ".agent_state",
    "workspace_blocked_paths": [],
    "secret_key": "model-chat-secret-key-change-in-production",
    "default_provider": "dtgpt",
    "provider_options": [
      "gemini",
      "dtgpt"
    ],
    "providers": {
      "gemini": {
        "api_key": "${MODEL_GEMINI_API_KEY}",
        "api_base_url": "https://generativelanguage.googleapis.com/v1beta",
        "default_model": "gemini-flash-latest",
        "model_options": [
          "gemini-flash-latest",
          "gemini-flash-lite-latest",
          "gemini-pro-latest",
          "gemini-3.1-pro-preview"
        ]
      },
      "dtgpt": {
        "api_key": "dk--YE4pWyKu2b3HNdxoXqPplwLLGCk1tKviv_FPBH5TEM",
        "api_key_env": "DTGPT_API_KEY",
        "api_key_header": "Authorization",
        "api_key_prefix": "Bearer",
        "api_base_url": "http://dtgpt.samsungds.net/llm/v1",
        "api_base_urls": [
          "http://dtgpt.samsungds.net/llm/v1"
        ],
        "default_model": "Kimi-K2.5",
        "model_options": [
          "Kimi-K2.5",
          "GLM4.7",
          "openai/gpt-oss-120b"
        ]
      }
    },
    "max_prompt_chars": 4000,
    "context_max_chars": 12000,
    "exec_timeout_seconds": 600,
    "api_timeout_seconds": 600,
    "stream_ttl_seconds": 900,
    "max_title_chars": 80,
    "max_provider_chars": 32,
    "max_model_chars": 80
  }
}
